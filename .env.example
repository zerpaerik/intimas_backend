# PostgreSQL (Railway lo inyecta automáticamente como DATABASE_URL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/intimas?schema=public"

# Secreto para firmar los JWT
JWT_SECRET="cambia-esto-en-produccion"

# Puerto (Railway inyecta PORT)
PORT=3001

# Orígenes permitidos por CORS (coma-separados). * permite todos.
CORS_ORIGIN="http://localhost:3000"
