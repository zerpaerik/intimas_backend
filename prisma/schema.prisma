// Esquema de datos — Intimas backend (PostgreSQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────── Autenticación / acceso ─────────
model Role {
  id          Int     @id // 1,2,7,10,11,12 (coinciden con el sistema original)
  nombre      String
  descripcion String?
  users       User[]
}

model Sede {
  id         Int        @id @default(autoincrement())
  nombre     String
  users      User[]
  atenciones Atencion[]
  pagos      Pago[]
  gastos     Gasto[]
}

model User {
  id                 Int        @id @default(autoincrement())
  nombre             String
  email              String     @unique
  password           String
  title              String?
  roleId             Int
  role               Role       @relation(fields: [roleId], references: [id])
  sedeId             Int?
  sede               Sede?      @relation(fields: [sedeId], references: [id])
  atenciones         Atencion[] @relation("AtencionRegistrador")
  atencionesAnuladas Atencion[] @relation("AtencionAnulador")
  pagos              Pago[]
  gastos             Gasto[]
  createdAt          DateTime   @default(now())
}

// ───────── Maestros (Archivos) ─────────
model Paciente {
  id              Int        @id @default(autoincrement())
  nombres         String
  apellidos       String
  tipoDoc         String?
  numDoc          String?
  fechaNacimiento DateTime?
  sexo            String?
  telefono        String?
  email           String?
  ocupacion       String?
  estadoCivil     String?
  direccion       String?
  alergias        String?
  antPatologicos  String?
  antFamiliares   String?
  grupoSanguineo  String?
  atenciones      Atencion[]
  consultas       Consulta[]
  antecedenteObst AntecedenteObstetrico?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Centro {
  id            Int           @id @default(autoincrement())
  nombre        String
  direccion     String?
  referencia    String?
  profesionales Profesional[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Laboratorio {
  id         Int      @id @default(autoincrement())
  nombre     String
  direccion  String?
  referencia String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Profesional {
  id           Int       @id @default(autoincrement())
  nombres      String
  apellidos    String
  cmp          String?
  nacimiento   DateTime?
  telefono     String?
  especialidad String?
  centroId     Int?
  centro       Centro?   @relation(fields: [centroId], references: [id])
  consultas    Consulta[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Personal {
  id        Int      @id @default(autoincrement())
  nombres   String
  apellidos String
  dni       String?
  direccion String?
  telefono  String?
  email     String?
  cargo     String?
  tipo      String?
  sesion    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Servicio {
  id             Int       @id @default(autoincrement())
  nombre         String
  tipo           String?
  precio         Decimal   @default(0) @db.Decimal(10, 2)
  porcentajePers Float     @default(0)
  porcentajeProf Float     @default(0)
  porcentajeTecn Float     @default(0)
  paquetes       Paquete[] @relation("PaqueteServicios")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Analisis {
  id         Int       @id @default(autoincrement())
  nombre     String
  precio     Decimal   @default(0) @db.Decimal(10, 2)
  costo      Decimal   @default(0) @db.Decimal(10, 2)
  porcentaje Float     @default(0)
  tiempo     String?
  material   String?
  paquetes   Paquete[] @relation("PaqueteAnalisis")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Material {
  id        Int      @id @default(autoincrement())
  nombre    String
  estatus   String   @default("Disponible")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Producto {
  id            Int      @id @default(autoincrement())
  nombre        String
  categoria     String?
  unidad        String?
  minimoCentral Int      @default(0)
  minimoLocal   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Paquete {
  id         Int        @id @default(autoincrement())
  nombre     String
  precio     Decimal    @default(0) @db.Decimal(10, 2)
  porcentaje Float      @default(0)
  consultas  Int        @default(0)
  controles  Int        @default(0)
  servicios  Servicio[] @relation("PaqueteServicios")
  analisis   Analisis[] @relation("PaqueteAnalisis")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

// ───────── Operacional: Atenciones ─────────
model Atencion {
  id            Int            @id @default(autoincrement())
  fecha         DateTime       @default(now())
  pacienteId    Int
  paciente      Paciente       @relation(fields: [pacienteId], references: [id])
  origenTipo    String         @default("Personal")
  origenValor   String?
  observaciones String?
  total         Decimal        @default(0) @db.Decimal(10, 2)
  pagado        Decimal        @default(0) @db.Decimal(10, 2)
  saldo         Decimal        @default(0) @db.Decimal(10, 2)
  estado        String         @default("Pendiente") // Pagado | Parcial | Pendiente
  usuarioId     Int?
  usuario       User?          @relation("AtencionRegistrador", fields: [usuarioId], references: [id])
  sedeId        Int?
  sede          Sede?          @relation(fields: [sedeId], references: [id])
  items         AtencionItem[]
  pagos         Pago[]
  consultas     Consulta[]

  // Anulación (soft delete) + auditoría
  anulada         Boolean   @default(false)
  anuladaAt       DateTime?
  anuladaPorId    Int?
  anuladaPor      User?     @relation("AtencionAnulador", fields: [anuladaPorId], references: [id])
  motivoAnulacion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
  @@index([pacienteId])
  @@index([sedeId])
  @@index([anulada])
}

model AtencionItem {
  id         Int      @id @default(autoincrement())
  atencionId Int
  atencion   Atencion @relation(fields: [atencionId], references: [id], onDelete: Cascade)
  kind       String
  nombre     String
  monto      Decimal  @default(0) @db.Decimal(10, 2)
}

// ───────── Finanzas: ledger de ingresos y egresos ─────────
model Pago {
  id         Int      @id @default(autoincrement())
  atencionId Int
  atencion   Atencion @relation(fields: [atencionId], references: [id], onDelete: Cascade)
  monto      Decimal  @db.Decimal(10, 2)
  metodo     String   @default("Efectivo") // Efectivo | Tarjeta | Depósito | Yape
  tipo       String   @default("ABONO_INICIAL") // ABONO_INICIAL | COBRO
  fecha      DateTime @default(now())
  sedeId     Int?
  sede       Sede?    @relation(fields: [sedeId], references: [id])
  usuarioId  Int?
  usuario    User?    @relation(fields: [usuarioId], references: [id])
  anulado    Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([fecha])
  @@index([sedeId])
  @@index([metodo])
  @@index([atencionId])
  @@index([anulado])
}

model Gasto {
  id              Int       @id @default(autoincrement())
  fecha           DateTime  @default(now())
  categoria       String?
  descripcion     String
  nota            String?
  monto           Decimal   @db.Decimal(10, 2)
  metodo          String    @default("Efectivo")
  proveedor       String?
  sedeId          Int?
  sede            Sede?     @relation(fields: [sedeId], references: [id])
  usuarioId       Int?
  usuario         User?     @relation(fields: [usuarioId], references: [id])
  anulada         Boolean   @default(false)
  anuladaAt       DateTime?
  anuladaPorId    Int?
  motivoAnulacion String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([fecha])
  @@index([sedeId])
  @@index([categoria])
  @@index([anulada])
}

// ───────── Clínico: consultas, historias y controles ─────────
model TipoConsulta {
  id           Int        @id @default(autoincrement())
  nombre       String
  precio       Decimal    @default(0) @db.Decimal(10, 2)
  especialidad String?
  prenatal     Boolean    @default(false)
  consultas    Consulta[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Consulta {
  id             Int              @id @default(autoincrement())
  fecha          DateTime         @default(now())
  pacienteId     Int
  paciente       Paciente         @relation(fields: [pacienteId], references: [id])
  atencionId     Int?
  atencion       Atencion?        @relation(fields: [atencionId], references: [id], onDelete: SetNull)
  tipoConsultaId Int?
  tipoConsulta   TipoConsulta?    @relation(fields: [tipoConsultaId], references: [id])
  tipoNombre     String
  especialidad   String?
  prenatal       Boolean          @default(false)
  especialistaId Int?
  especialista   Profesional?     @relation(fields: [especialistaId], references: [id])
  estado         String           @default("Pendiente") // Pendiente | Atendida
  sedeId         Int?
  usuarioId      Int?
  historia       HistoriaClinica?
  control        ControlPrenatal?
  createdAt      DateTime         @default(now())

  @@index([pacienteId])
  @@index([estado])
  @@index([fecha])
}

model HistoriaClinica {
  id                    Int      @id @default(autoincrement())
  consultaId            Int      @unique
  consulta              Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  pacienteId            Int
  especialistaId        Int?
  fecha                 DateTime @default(now())
  motivo                String?
  presionArterial       String?
  pulso                 String?
  temperatura           String?
  peso                  String?
  talla                 String?
  examenFisico          String?
  diagnosticoPresuntivo String?
  diagnosticoDefinitivo String?
  cie                   String?
  plan                  String?
  observaciones         String?
  proximaCita           String?
  datosExtra            Json?
  usuarioId             Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ControlPrenatal {
  id                 Int      @id @default(autoincrement())
  consultaId         Int      @unique
  consulta           Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  pacienteId         Int
  especialistaId     Int?
  fecha              DateTime @default(now())
  semanaGestacional  Int?
  peso               String?
  presionArterial    String?
  fcf                String?
  alturaUterina      String?
  movimientosFetales String?
  edema              String?
  examenFisico       String?
  diagnostico        String?
  plan               String?
  proximaCita        String?
  observaciones      String?
  usuarioId          Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AntecedenteObstetrico {
  id            Int       @id @default(autoincrement())
  pacienteId    Int       @unique
  paciente      Paciente  @relation(fields: [pacienteId], references: [id])
  gestas        Int?
  partos        Int?
  abortos       Int?
  cesareas      Int?
  hijosVivos    Int?
  fum           DateTime?
  fpp           DateTime?
  tipoSangre    String?
  observaciones String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
