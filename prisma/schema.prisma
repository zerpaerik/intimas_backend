// Esquema de datos — Intimas backend (PostgreSQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────── Autenticación / acceso ─────────
model Role {
  id          Int     @id // 1,2,7,10,11,12 (coinciden con el sistema original)
  nombre      String
  descripcion String?
  users       User[]
}

model Sede {
  id         Int          @id @default(autoincrement())
  nombre     String
  users      User[]
  atenciones Atencion[]
  pagos      Pago[]
  gastos     Gasto[]
  cajas      CajaSesion[]
}

// Sesión de caja: el cajero abre, acumula sus operaciones del turno y cierra con arqueo.
model CajaSesion {
  id                  Int       @id @default(autoincrement())
  usuarioId           Int
  usuario             User      @relation("CajaUsuario", fields: [usuarioId], references: [id])
  sedeId              Int?
  sede                Sede?     @relation(fields: [sedeId], references: [id])
  estado              String    @default("Abierta") // Abierta | Cerrada
  montoInicial        Decimal   @default(0) @db.Decimal(10, 2)
  observacionApertura String?
  fechaApertura       DateTime  @default(now())
  fechaCierre         DateTime?
  cerradaPorId        Int?
  cerradaPor          User?     @relation("CajaCerrador", fields: [cerradaPorId], references: [id])
  observacionCierre   String?
  arqueo              Json?     // congelado al cerrar: { ingresos, gastos, esperado, contado, diferencia } por método
  totalIngresos       Decimal?  @db.Decimal(10, 2)
  totalGastos         Decimal?  @db.Decimal(10, 2)
  totalDiferencia     Decimal?  @db.Decimal(10, 2)
  pagos               Pago[]
  gastos              Gasto[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([usuarioId])
  @@index([estado])
  @@index([sedeId])
  @@index([fechaApertura])
}

model User {
  id                 Int        @id @default(autoincrement())
  nombre             String
  email              String     @unique
  password           String
  title              String?
  roleId             Int
  role               Role       @relation(fields: [roleId], references: [id])
  sedeId             Int?
  sede               Sede?      @relation(fields: [sedeId], references: [id])
  atenciones         Atencion[] @relation("AtencionRegistrador")
  atencionesAnuladas Atencion[] @relation("AtencionAnulador")
  pagos              Pago[]
  gastos             Gasto[]
  cajas              CajaSesion[] @relation("CajaUsuario")
  cajasCerradas      CajaSesion[] @relation("CajaCerrador")
  createdAt          DateTime   @default(now())
}

// ───────── Maestros (Archivos) ─────────
model Paciente {
  id              Int        @id @default(autoincrement())
  nombres         String
  apellidos       String
  tipoDoc         String?
  numDoc          String?
  fechaNacimiento DateTime?
  sexo            String?
  telefono        String?
  email           String?
  ocupacion       String?
  estadoCivil     String?
  direccion       String?
  alergias        String?
  antPatologicos  String?
  antFamiliares   String?
  grupoSanguineo  String?
  // Antecedentes del formato Historia Clínica (se cargan una vez, reutilizables)
  antPersonales      String?
  antEpidemiologicos String?
  antQuirurgicos     String?
  antOtros           String?
  facebook           String?
  // Contacto familiar / acompañante
  familiarNombre     String?
  familiarParentesco String?
  familiarDni        String?
  atenciones      Atencion[]
  consultas       Consulta[]
  gestaciones     Gestacion[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Centro {
  id            Int           @id @default(autoincrement())
  nombre        String
  direccion     String?
  referencia    String?
  profesionales Profesional[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Laboratorio {
  id         Int      @id @default(autoincrement())
  nombre     String
  direccion  String?
  referencia String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Profesional {
  id           Int       @id @default(autoincrement())
  nombres      String
  apellidos    String
  cmp          String?
  nacimiento   DateTime?
  telefono     String?
  especialidad String?
  centroId     Int?
  centro       Centro?   @relation(fields: [centroId], references: [id])
  consultorio  String?
  turno        String?
  codigoSalud  String?
  consultas    Consulta[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Personal {
  id        Int      @id @default(autoincrement())
  nombres   String
  apellidos String
  dni       String?
  direccion String?
  telefono  String?
  email     String?
  cargo     String?
  tipo      String?
  sesion    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Servicio {
  id             Int       @id @default(autoincrement())
  nombre         String
  tipo           String?
  precio         Decimal   @default(0) @db.Decimal(10, 2)
  porcentajePers Float     @default(0)
  porcentajeProf Float     @default(0)
  porcentajeTecn Float     @default(0)
  paquetes       Paquete[] @relation("PaqueteServicios")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Analisis {
  id         Int       @id @default(autoincrement())
  nombre     String
  precio     Decimal   @default(0) @db.Decimal(10, 2)
  costo      Decimal   @default(0) @db.Decimal(10, 2)
  porcentaje Float     @default(0)
  tiempo     String?
  material   String?
  paquetes   Paquete[] @relation("PaqueteAnalisis")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Material {
  id        Int      @id @default(autoincrement())
  nombre    String
  estatus   String   @default("Disponible")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Producto {
  id            Int      @id @default(autoincrement())
  nombre        String
  categoria     String?
  unidad        String?
  minimoCentral Int      @default(0)
  minimoLocal   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Paquete {
  id         Int        @id @default(autoincrement())
  nombre     String
  precio     Decimal    @default(0) @db.Decimal(10, 2)
  porcentaje Float      @default(0)
  consultas  Int        @default(0)
  controles  Int        @default(0)
  servicios  Servicio[] @relation("PaqueteServicios")
  analisis   Analisis[] @relation("PaqueteAnalisis")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

// ───────── Operacional: Atenciones ─────────
model Atencion {
  id            Int            @id @default(autoincrement())
  fecha         DateTime       @default(now())
  pacienteId    Int
  paciente      Paciente       @relation(fields: [pacienteId], references: [id])
  origenTipo    String         @default("Personal")
  origenValor   String?
  observaciones String?
  total         Decimal        @default(0) @db.Decimal(10, 2)
  pagado        Decimal        @default(0) @db.Decimal(10, 2)
  saldo         Decimal        @default(0) @db.Decimal(10, 2)
  estado        String         @default("Pendiente") // Pagado | Parcial | Pendiente
  usuarioId     Int?
  usuario       User?          @relation("AtencionRegistrador", fields: [usuarioId], references: [id])
  sedeId        Int?
  sede          Sede?          @relation(fields: [sedeId], references: [id])
  items         AtencionItem[]
  pagos         Pago[]
  consultas     Consulta[]

  // Anulación (soft delete) + auditoría
  anulada         Boolean   @default(false)
  anuladaAt       DateTime?
  anuladaPorId    Int?
  anuladaPor      User?     @relation("AtencionAnulador", fields: [anuladaPorId], references: [id])
  motivoAnulacion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
  @@index([pacienteId])
  @@index([sedeId])
  @@index([anulada])
}

model AtencionItem {
  id         Int      @id @default(autoincrement())
  atencionId Int
  atencion   Atencion @relation(fields: [atencionId], references: [id], onDelete: Cascade)
  kind       String
  nombre     String
  monto      Decimal  @default(0) @db.Decimal(10, 2)
}

// ───────── Finanzas: ledger de ingresos y egresos ─────────
model Pago {
  id         Int      @id @default(autoincrement())
  atencionId Int
  atencion   Atencion @relation(fields: [atencionId], references: [id], onDelete: Cascade)
  monto      Decimal  @db.Decimal(10, 2)
  metodo     String   @default("Efectivo") // Efectivo | Tarjeta | Depósito | Yape
  tipo       String   @default("ABONO_INICIAL") // ABONO_INICIAL | COBRO
  fecha      DateTime @default(now())
  sedeId     Int?
  sede       Sede?    @relation(fields: [sedeId], references: [id])
  usuarioId  Int?
  usuario    User?    @relation(fields: [usuarioId], references: [id])
  anulado    Boolean  @default(false)
  cajaSesionId Int?
  cajaSesion CajaSesion? @relation(fields: [cajaSesionId], references: [id])
  createdAt  DateTime @default(now())

  @@index([fecha])
  @@index([sedeId])
  @@index([metodo])
  @@index([atencionId])
  @@index([anulado])
  @@index([cajaSesionId])
}

model Gasto {
  id              Int       @id @default(autoincrement())
  fecha           DateTime  @default(now())
  categoria       String?
  descripcion     String
  nota            String?
  monto           Decimal   @db.Decimal(10, 2)
  metodo          String    @default("Efectivo")
  proveedor       String?
  sedeId          Int?
  sede            Sede?     @relation(fields: [sedeId], references: [id])
  usuarioId       Int?
  usuario         User?     @relation(fields: [usuarioId], references: [id])
  anulada         Boolean   @default(false)
  anuladaAt       DateTime?
  anuladaPorId    Int?
  motivoAnulacion String?
  cajaSesionId    Int?
  cajaSesion      CajaSesion? @relation(fields: [cajaSesionId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([fecha])
  @@index([sedeId])
  @@index([categoria])
  @@index([anulada])
  @@index([cajaSesionId])
}

// ───────── Clínico: consultas, historias y controles ─────────
model TipoConsulta {
  id           Int        @id @default(autoincrement())
  nombre       String
  precio       Decimal    @default(0) @db.Decimal(10, 2)
  especialidad String?
  prenatal     Boolean    @default(false)
  pediatrico   Boolean    @default(false)
  gineco       Boolean    @default(false)
  formato      String     @default("general") // general | ginecologica | prenatal | pediatrico
  consultas    Consulta[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Consulta {
  id             Int              @id @default(autoincrement())
  fecha          DateTime         @default(now())
  pacienteId     Int
  paciente       Paciente         @relation(fields: [pacienteId], references: [id])
  atencionId     Int?
  atencion       Atencion?        @relation(fields: [atencionId], references: [id], onDelete: SetNull)
  tipoConsultaId Int?
  tipoConsulta   TipoConsulta?    @relation(fields: [tipoConsultaId], references: [id])
  tipoNombre     String
  especialidad   String?
  prenatal       Boolean          @default(false)
  pediatrico     Boolean          @default(false)
  gineco         Boolean          @default(false)
  especialistaId Int?
  especialista   Profesional?     @relation(fields: [especialistaId], references: [id])
  estado         String           @default("Pendiente") // Pendiente | Atendida
  sedeId         Int?
  usuarioId      Int?
  historia       HistoriaClinica?
  control        ControlPrenatal?
  pediatrica     HistoriaPediatrica?
  createdAt      DateTime         @default(now())

  @@index([pacienteId])
  @@index([estado])
  @@index([fecha])
}

model HistoriaClinica {
  id              Int      @id @default(autoincrement())
  consultaId      Int      @unique
  consulta        Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  pacienteId      Int
  especialistaId  Int?
  fecha           DateTime @default(now())
  // 2 · Enfermedad actual
  enfInicio       String?
  enfCurso        String?
  enfRelato       String?
  // 4 · Funciones vitales + examen general
  peso            String?
  fc              String?
  fr              String?
  presionArterial String?
  talla           String?
  temperatura     String?
  examenGeneral   String?
  // 6 · Procedimientos / 8 · Observaciones
  procedimientos  String?
  observaciones   String?
  diagnosticos    Diagnostico[]
  tratamientos    Tratamiento[]
  cerrada         Boolean  @default(false)
  fechaCierre     DateTime?
  usuarioId       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Diagnostico {
  id          Int             @id @default(autoincrement())
  historiaId  Int
  historia    HistoriaClinica @relation(fields: [historiaId], references: [id], onDelete: Cascade)
  cie10       String
  descripcion String?
}

model Tratamiento {
  id           Int             @id @default(autoincrement())
  historiaId   Int
  historia     HistoriaClinica @relation(fields: [historiaId], references: [id], onDelete: Cascade)
  medicamento  String
  presentacion String?
  cantidad     String?
  dosis        String?
  dias         String?
}

model Cie10 {
  codigo      String @id
  descripcion String

  @@index([descripcion])
}

// Historia Clínica Pediátrica (formato estandarizado pediátrico)
model HistoriaPediatrica {
  id              Int      @id @default(autoincrement())
  consultaId      Int      @unique
  consulta        Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  pacienteId      Int
  especialistaId  Int?
  fecha           DateTime @default(now())
  // 1 · Identificación pediátrica
  cama            String?
  informante      String?
  lugarNacimiento String?
  procedencia     String?
  seguro          String?
  madreNombre     String?
  padreNombre     String?
  servicioIngreso String?
  referido        String?
  // 2 · Enfermedad actual
  motivoConsulta      String?
  tiempoEnfermedad    String?
  formaInicio         String?
  relato              String?
  datosNegativos      String?
  funcionesBiologicas String?
  revisionSistemas    String?
  // 3 · Antecedentes personales
  antPerinatales   String?
  pesoNacer        String?
  tallaNacer       String?
  apgar            String?
  antNutricionales String?
  desarrollo       String?
  escolaridad      String?
  inmunizaciones   String?
  antPatologicos   String?
  // 4-5 · Familiares y socioeconómicos
  antFamiliares      String?
  antSocioeconomicos String?
  // 7 · Examen físico · somatometría
  peso               String?
  talla              String?
  pc                 String?
  perimetroAbdominal String?
  imc                String?
  fc                 String?
  fr                 String?
  ta                 String?
  temperatura        String?
  percentiles        String?
  inspeccionGeneral  String?
  // 10 · Hipótesis diagnóstica
  dxPatologia   String?
  dxCrecimiento String?
  // 11-12 · Planes
  planEstudio String?
  planManejo  String?
  // Cierre
  cerrada     Boolean   @default(false)
  fechaCierre DateTime?
  usuarioId   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([pacienteId])
}

model ControlPrenatal {
  id                 Int        @id @default(autoincrement())
  consultaId         Int        @unique
  consulta           Consulta   @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  gestacionId        Int?
  gestacion          Gestacion? @relation(fields: [gestacionId], references: [id], onDelete: SetNull)
  pacienteId         Int
  especialistaId     Int?
  fecha              DateTime   @default(now())
  semanaGestacional  Int?
  peso               String?
  temperatura        String?
  presionArterial    String?
  pulso              String?
  alturaUterina      String?
  presentacion       String?
  fcf                String?
  movimientosFetales String?
  edema              String?
  consejeria         String?
  sulfatoFerroso     String?
  perfilBiofisico    String?
  serologia          String?
  glucosa            String?
  vih                String?
  hemoglobina        String?
  examenFisico       String?
  diagnostico        String?
  diagDefinitivo     String?
  exAux              String?
  plan               String?
  proximaCita        String?
  observaciones      String?
  cerrada            Boolean    @default(false)
  fechaCierre        DateTime?
  usuarioId          Int?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([gestacionId])
}

// Gestación = serie de controles prenatales (carné). Se cierra al terminar el embarazo.
model Gestacion {
  id             Int               @id @default(autoincrement())
  pacienteId     Int
  paciente       Paciente          @relation(fields: [pacienteId], references: [id])
  estado         String            @default("Abierta") // Abierta | Cerrada
  // Antecedentes obstétricos de esta gestación
  gestas         Int?
  partos         Int?
  abortos        Int?
  cesareas       Int?
  vaginales      Int?
  nacidosVivos   Int?
  viven          Int?
  nacidosMuertos Int?
  // Cabecera del embarazo
  fum            DateTime?
  fpp            DateTime?
  ecoeg          String?
  tipoSangre     String?
  factorRh       String?
  // Exámenes de base
  orina          String?
  urea           String?
  creatinina     String?
  bk             String?
  torch          String?
  observaciones  String?
  // Cierre
  fechaCierre    DateTime?
  motivoCierre   String?
  controles      ControlPrenatal[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([pacienteId])
  @@index([estado])
}
